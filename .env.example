# ══════════════════════════════════════════════════════════════
# Lumen — Environment Variables
# ══════════════════════════════════════════════════════════════
#
# Copy this file to `.env` and fill in real values for local dev:
#     cp .env.example .env
#
# NEVER commit .env. Only this .env.example file is tracked.
#
# Variables prefixed with PUBLIC_ are exposed to the client.
# All others are server-only and must never leak to the browser.
#
# ══════════════════════════════════════════════════════════════


# ──────────────────────────────────────────────────────────────
# PHASE 0 — FOUNDATION
# ──────────────────────────────────────────────────────────────

# Runtime environment: development | staging | production
NODE_ENV=development

# Public base URL of the app (no trailing slash)
# Local dev: http://localhost:5173
# Production: https://lumen.so
PUBLIC_APP_URL=http://localhost:5173

# Public app name (used in emails, meta tags, UI)
PUBLIC_APP_NAME=Lumen


# ──────────────────────────────────────────────────────────────
# PHASE 1 — DATABASE (Neon Postgres)
# ──────────────────────────────────────────────────────────────

# Neon Postgres connection string (pooled connection for app)
# Get from: https://console.neon.tech → Project → Connect
# Format: postgresql://user:password@host.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/lumen?sslmode=require

# Direct (unpooled) connection for migrations and long-running operations
# Use the "Direct connection" string from Neon console
DATABASE_URL_UNPOOLED=postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/lumen?sslmode=require


# ──────────────────────────────────────────────────────────────
# PHASE 3 — AUTHENTICATION (Better Auth)
# ──────────────────────────────────────────────────────────────

# Secret used to sign session tokens, cookies, and verification codes
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Base URL for auth callbacks (usually same as PUBLIC_APP_URL)
BETTER_AUTH_URL=http://localhost:5173

# OAuth — Google (optional, enable in Phase 3.x)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth — GitHub (optional, enable in Phase 3.x)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=


# ──────────────────────────────────────────────────────────────
# PHASE 7 — EMAIL (Resend)
# ──────────────────────────────────────────────────────────────

# Resend API key
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_replace_me

# From address for transactional email (must be verified domain in Resend)
EMAIL_FROM="Lumen <no-reply@lumen.so>"

# Reply-to address for user-initiated conversations
EMAIL_REPLY_TO=support@lumen.so


# ──────────────────────────────────────────────────────────────
# PHASE 8 — STRIPE (Payments)
# ──────────────────────────────────────────────────────────────

# Stripe secret key (server-only, never expose)
# Test mode: sk_test_...
# Live mode: sk_live_...
STRIPE_SECRET_KEY=sk_test_replace_me

# Stripe publishable key (safe for client)
PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_replace_me

# Stripe webhook signing secret (set after `stripe listen` in dev)
# Generate with: stripe listen --forward-to localhost:5173/api/webhooks/stripe
STRIPE_WEBHOOK_SECRET=whsec_replace_me

# Optional: Stripe account country (affects tax calculation)
STRIPE_ACCOUNT_COUNTRY=US


# ──────────────────────────────────────────────────────────────
# PHASE 12 — AI CO-PILOT (Anthropic Claude)
# ──────────────────────────────────────────────────────────────

# Anthropic API key for the in-app AI co-pilot
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-replace_me

# Default Claude model for the co-pilot
ANTHROPIC_MODEL=claude-opus-4-7


# ──────────────────────────────────────────────────────────────
# PHASE 14 — OBSERVABILITY (Sentry)
# ──────────────────────────────────────────────────────────────

# Sentry DSN for error tracking
# Get from: https://sentry.io → Project Settings → Client Keys (DSN)
PUBLIC_SENTRY_DSN=

# Sentry auth token (for sourcemap upload during build)
SENTRY_AUTH_TOKEN=

# Sentry organization + project slugs
SENTRY_ORG=billyribeiro-ux
SENTRY_PROJECT=lumen


# ──────────────────────────────────────────────────────────────
# PHASE 15 — DESKTOP (Tauri 2)
# ──────────────────────────────────────────────────────────────

# Tauri signing key password (for auto-updater signature)
# Generate with: pnpm tauri signer generate
TAURI_SIGNING_PRIVATE_KEY=
TAURI_SIGNING_PRIVATE_KEY_PASSWORD=


# ──────────────────────────────────────────────────────────────
# OPTIONAL — Rate Limiting / Caching (Upstash Redis)
# ──────────────────────────────────────────────────────────────

# Upstash Redis URL (for rate limiting, session cache)
# Get from: https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=


# ──────────────────────────────────────────────────────────────
# DEV TOOLING
# ──────────────────────────────────────────────────────────────

# Drizzle Studio port (database GUI, dev only)
DRIZZLE_STUDIO_PORT=4983

# Enable verbose logging in dev
DEBUG=false
