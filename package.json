{
  "name": "lumen",
  "version": "0.1.0",
  "private": true,
  "description": "Keyboard-driven knowledge OS for builders — your second brain, lit.",
  "homepage": "https://lumen.so",
  "repository": {
    "type": "git",
    "url": "https://github.com/billyribeiro-ux/lumen.git"
  },
  "license": "MIT",
  "author": "Billy Ribeiro <welberribeirodrums@gmail.com>",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write '**/*.svelte'",
    "format:check": "biome format . && prettier --check '**/*.svelte'",
    "ci:lint": "biome ci . && prettier --check '**/*.svelte'",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit --run && pnpm test:e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-auto": "^7.0.1",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@vitest/browser-playwright": "^4.1.3",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  }
}
