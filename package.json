{
  "name": "lumen",
  "version": "0.8.0",
  "private": true,
  "description": "Keyboard-driven knowledge OS for builders — your second brain, lit.",
  "homepage": "https://lumen.so",
  "repository": {
    "type": "git",
    "url": "https://github.com/billyribeiro-ux/lumen.git"
  },
  "license": "MIT",
  "author": "Billy Ribeiro <welberribeirodrums@gmail.com>",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22 <25",
    "pnpm": ">=10 <11"
  },
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "prepare": "svelte-kit sync || echo ''",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write . && prettier --write '**/*.svelte'",
    "format:check": "biome format . && prettier --check '**/*.svelte'",
    "ci:lint": "biome ci . && prettier --check '**/*.svelte'",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test": "pnpm test:unit --run && pnpm test:e2e",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:check": "drizzle-kit check",
    "db:seed": "tsx scripts/seed/index.ts",
    "db:wipe": "tsx scripts/seed/wipe.ts",
    "db:reset": "tsx scripts/seed/reset.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.13",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@node-rs/argon2": "^2.0.2",
    "@playwright/test": "^1.59.1",
    "@sveltejs/adapter-vercel": "^6.3.3",
    "@sveltejs/kit": "^2.57.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@types/node": "^25.6.0",
    "@types/ws": "^8.18.1",
    "@vitest/browser-playwright": "^4.1.3",
    "drizzle-kit": "^0.31.10",
    "lefthook": "^2.1.6",
    "playwright": "^1.59.1",
    "prettier": "^3.8.1",
    "prettier-plugin-svelte": "^3.5.1",
    "svelte": "^5.55.2",
    "svelte-check": "^4.4.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vite": "^8.0.7",
    "vitest": "^4.1.3",
    "vitest-browser-svelte": "^2.1.0"
  },
  "dependencies": {
    "@better-auth/passkey": "^1.6.9",
    "@iconify/svelte": "^5.2.1",
    "@neondatabase/serverless": "^1.1.0",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.37.0",
    "better-auth": "^1.6.9",
    "bits-ui": "^2.18.0",
    "drizzle-orm": "^0.45.2",
    "resend": "^6.12.2",
    "shiki": "^4.0.2",
    "sveltekit-superforms": "^2.30.1",
    "valibot": "^1.3.1",
    "ws": "^8.20.0"
  }
}
