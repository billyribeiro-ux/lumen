{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lumen",
  "identifier": "so.lumen.desktop",
  "version": "1.1.0",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../build/client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Lumen",
        "width": 1280,
        "height": 820,
        "minWidth": 480,
        "minHeight": 320,
        "decorations": true,
        "transparent": false,
        "fullscreen": false,
        "resizable": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 12, "y": 14 }
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": null
    },
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "title": "Lumen"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "msi", "appimage", "deb"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "minimumSystemVersion": "11.0",
      "entitlements": null,
      "providerShortName": null,
      "signingIdentity": null
    },
    "windows": {
      "wix": null
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": ["https://lumen.so/api/desktop/updates/{{target}}/{{current_version}}"],
      "pubkey": "REPLACE_WITH_TAURI_SIGNER_PUBLIC_KEY"
    },
    "deep-link": {
      "desktop": {
        "schemes": ["lumen"]
      }
    },
    "global-shortcut": {
      "default": true
    }
  }
}
