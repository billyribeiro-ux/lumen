# ──────────────────────────────────────────────────────────
# Lumen — .gitignore
# PE7 Architecture Standard
# ──────────────────────────────────────────────────────────

# ─── Dependencies ───────────────────────────────────────────
node_modules/
.pnpm-store/
.pnpm-debug.log*
jspm_packages/
bower_components/

# ─── Package Manager Lockfiles (pnpm only) ──────────────────
package-lock.json
yarn.lock
bun.lockb
bun.lock

# ─── SvelteKit ──────────────────────────────────────────────
.svelte-kit/
build/
.vercel/
.netlify/
.cloudflare/

# ─── Vite ───────────────────────────────────────────────────
.vite/
dist/
dist-ssr/
*.local

# ─── TypeScript ─────────────────────────────────────────────
*.tsbuildinfo
.tsbuildinfo

# ─── Environment Variables (NEVER COMMIT) ───────────────────
.env
.env.local
.env.*.local
.env.development
.env.production
.env.test
.env.staging
!.env.example

# ─── Secrets & Keys ─────────────────────────────────────────
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/
.secrets/
credentials.json
service-account*.json

# ─── Database ───────────────────────────────────────────────
*.db
*.db-journal
*.sqlite
*.sqlite3
*.sqlite3-journal
drizzle/meta/_journal.json.backup

# ─── Testing ────────────────────────────────────────────────
coverage/
.nyc_output/
test-results/
playwright-report/
playwright/.cache/
blob-report/
.vitest-cache/

# ─── Logs ───────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ─── Caches ─────────────────────────────────────────────────
.cache/
.turbo/
.eslintcache
.stylelintcache
.biomecache
.parcel-cache/
.next/
.nuxt/

# ─── Tauri 2 (Desktop App) ──────────────────────────────────
src-tauri/target/
src-tauri/gen/
src-tauri/Cargo.lock
src-tauri/WixTools/
src-tauri/.cargo/
*.app/
*.dmg
*.msi
*.exe
*.AppImage
*.deb
*.rpm

# ─── Rust ───────────────────────────────────────────────────
target/
**/*.rs.bk
Cargo.lock

# ─── macOS ──────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# ─── Windows ────────────────────────────────────────────────
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msm
*.msp
*.lnk

# ─── Linux ──────────────────────────────────────────────────
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ─── Editors / IDEs ─────────────────────────────────────────
# VS Code
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
.history/

# Cursor / Windsurf
.cursor/
.windsurf/
.windsurfrules
.cursorrules

# JetBrains (WebStorm, IntelliJ)
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~
.netrwhist
Session.vim

# Emacs
*~
\#*\#
.\#*
.emacs.desktop
.emacs.desktop.lock

# Zed
.zed/

# ─── AI Coding Assistants ───────────────────────────────────
.claude/
.aider*
.continue/

# ─── Observability / Monitoring ─────────────────────────────
.sentry-build-plugin/
sentry-cli.log

# ─── Documentation Builds ───────────────────────────────────
docs/.vitepress/dist/
docs/.vitepress/cache/

# ─── Miscellaneous ──────────────────────────────────────────
.tmp/
.temp/
tmp/
temp/
*.pid
*.seed
*.pid.lock
.DS_Store?
